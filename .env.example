# MilaServ Portal — environment template
#
# Copy to `.env` and fill in real values. `.env` is git-ignored and must
# NEVER be committed. Values below are placeholders only.

# --- Supabase (server-side) -------------------------------------------------
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
# Anon/publishable key. Safe to expose to the browser; RLS is the boundary.
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# --- Supabase (client-side, inlined by Vite at build time) ------------------
# Only ever put browser-safe values behind a VITE_ prefix — anything here is
# baked into the public bundle.
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# --- Supabase service role (server-only, NEVER prefixed with VITE_) ---------
# Bypasses RLS. Set only in the deployment environment (e.g. Cloudflare Worker
# secrets). Never commit a real value and never expose it to client code.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Yeastar PBX (server-only) ---------------------------------------------
YEASTAR_BASE_URL=""
YEASTAR_CLIENT_ID=""
YEASTAR_CLIENT_SECRET=""
YEASTAR_UTC_OFFSET_MINUTES="180"
YEASTAR_DATETIME_FORMAT="yyyy/MM/dd HH:mm:ss"
